# Copy to .env.local (do not commit secrets)
#
# Razorpay (optional). If not set, app will use COD only.
REACT_APP_RAZORPAY_KEY_ID=rzp_test_yourkey

# Live mandi prices (Agmarknet via data.gov.in)
# 1) Register/login at data.gov.in
# 2) Generate API key
# 3) Set it in the server environment (not REACT_APP_*):
DATA_GOV_IN_API_KEY=your_data_gov_in_key

